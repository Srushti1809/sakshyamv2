{
  "version": 2,
  "builds": [
    {
      "src": "Sakshyam-v2.html",
      "use": "@vercel/static"
    },
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "main.py"
    },
    {
      "src": "/(.*)",
      "dest": "Sakshyam-v2.html"
    }
  ]
}
